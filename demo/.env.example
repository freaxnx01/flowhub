# FlowHub public-demo .env — copy to .env on the VPS-DE host. Gitignored.
#
# See docs/runbooks/public-demo.md for the operator runbook.

# --- Required ----------------------------------------------------------------

# OpenRouter key with a $1/mo hard cap configured in the OpenRouter dashboard.
# DO NOT reuse the developer-side key — this one must be rotation-safe and budgeted.
Ai__OpenRouter__ApiKey=sk-or-v1-...

# --- Optional overrides ------------------------------------------------------

# Override the default Gemma 4 31B free model if a better free option lands.
# Ai__OpenRouter__Model=google/gemma-4-31b-it:free

# Reset cadence in seconds (default 900 = 15 minutes).
# RESET_INTERVAL_SECONDS=900

# Traefik docker network name on the VPS-DE host. The demo compose attaches
# flowhub.web to this network so the host's Traefik can route demo.flowhub…
# to it. Defaults to `traefik_public`.
# TRAEFIK_NETWORK=traefik_public

# Postgres + RabbitMQ creds are demo-local — randomise per deployment.
POSTGRES_PASSWORD=demo-secret-rotate-me
RABBITMQ_USER=flowhub
RABBITMQ_PASSWORD=demo-secret-rotate-me

# Service credentials (Vikunja / Wallabag / Paperless) below are LIVE logins shown
# in the demo banner. SECURITY (issue #100): rotate the passwords off the published
# `flowhub-demo` default per deployment — set the *_PASSWORD lines to a fresh value.
# The banner reflects whatever you set, so the demo login shown stays correct.
# (Vikunja open registration intentionally stays on: the bootstrap registers the
#  demo user via POST /register, so it strictly needs it.)

# --- Vikunja (task board) --- live; demo user bootstrapped on first start -----
# VIKUNJA_PUBLIC_URL=https://vikunja.demo.flowhub.freaxnx01.ch
# VIKUNJA_DEMO_USER=flowhub
VIKUNJA_DEMO_PASSWORD=demo-secret-rotate-me
# VIKUNJA_DEMO_PROJECT=Inbox
VIKUNJA_JWT_SECRET=demo-jwt-secret-rotate-me

# --- Wallabag (read-later) --- OAuth API client is auto-created at runtime ----
# by the flowhub.wallabag-client init container; do NOT set client id/secret here.
# Only the demo user credentials and public URL are operator-facing.
# WALLABAG_PUBLIC_URL=https://wallabag.demo.flowhub.freaxnx01.ch
# WALLABAG_DEMO_USER=flowhub
WALLABAG_DEMO_PASSWORD=demo-secret-rotate-me

# --- paperless-ngx (document archive) --- admin created on first boot ---------
# PAPERLESS_PUBLIC_URL=https://paperless.demo.flowhub.freaxnx01.ch
# PAPERLESS_ADMIN_USER=flowhub
PAPERLESS_ADMIN_PASSWORD=demo-secret-rotate-me

# --- Deliberately UNSET ------------------------------------------------------
# The demo compose overlay sets the following to "" regardless of .env contents,
# so leave them out. Listed here so a future contributor knows why:
#   Embeddings__*        — search returns 503 ProblemDetails (transparent posture)
#   Auth__OIDC__*        — DemoAuthHandler auto-signs (no login)
