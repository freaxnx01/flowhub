@namespace FlowHub.Web.Components.DashboardCards

<MudCard Outlined="true">
    <MudCardContent>
        <MudText Typo="Typo.subtitle1" Class="mb-2">Integration health</MudText>
        @if (Integrations is null)
        {
            @for (var i = 0; i < 4; i++)
            {
                <MudSkeleton Width="100%" Class="mb-1" />
            }
        }
        else if (Integrations.Count == 0)
        {
            <MudText Typo="Typo.body2">No integrations configured yet — no activity to show.</MudText>
        }
        else
        {
            <MudStack Spacing="1">
                @foreach (var integration in Integrations)
                {
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <HealthDot Status="@integration.Status" />
                        <MudText Typo="Typo.body2" Style="min-width:140px;">@integration.Name</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Default">@integration.Status.ToString().ToLowerInvariant()</MudText>
                        <MudSpacer />
                        <MudText Typo="Typo.body2" Color="Color.Default">@FormatLastWrite(integration)</MudText>
                    </MudStack>
                }
            </MudStack>
        }
    </MudCardContent>
    <MudCardActions>
        <MudButton Variant="Variant.Text" EndIcon="@Icons.Material.Filled.ArrowForward" OnClick="OnManageClickInternal">
            Manage integrations
        </MudButton>
    </MudCardActions>
</MudCard>
