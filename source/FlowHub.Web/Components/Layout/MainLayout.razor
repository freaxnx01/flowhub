@inherits LayoutComponentBase

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudTooltip Text="Toggle navigation">
            <MudIconButton Icon="@Icons.Material.Filled.Menu"
                           Color="Color.Inherit"
                           Edge="Edge.Start"
                           OnClick="ToggleDrawer" />
        </MudTooltip>
        <MudImage Src="flowhub-logo.png" Alt="FlowHub" Height="32" Class="ml-2" />
        <MudSpacer />
        <QuickCaptureField DemoMode="DemoMode" />
        <MudSpacer />
        @* TODO Block 5 — UserMenu (avatar + theme toggle + OIDC logout) *@
        <MudTooltip Text="Dev Operator">
            <MudIconButton Icon="@Icons.Material.Filled.AccountCircle"
                           Color="Color.Inherit"
                           Edge="Edge.End" />
        </MudTooltip>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Variant="DrawerVariant.Mini" OpenMiniOnHover="false" Elevation="1">
        <MudNavMenu>
            <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>
            <MudNavLink Href="captures" Icon="@Icons.Material.Filled.GridView">Captures</MudNavLink>
            <MudNavLink Href="captures/new" Icon="@Icons.Material.Filled.Add">New Capture</MudNavLink>
            <MudNavLink Href="skills" Icon="@Icons.Material.Filled.Settings">Skills</MudNavLink>
            <MudNavLink Href="integrations" Icon="@Icons.Material.Filled.SwapHoriz">Integrations</MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent>
        @if (DemoMode)
        {
            <DemoBanner BannerText="@DemoBannerText"
                        RepoUrl="@DemoRepoUrl"
                        SkillBoardUrl="@DemoSkillBoardUrl"
                        ZitateBoardUrl="@DemoZitateBoardUrl"
                        WallabagUrl="@DemoWallabagUrl"
                        PaperlessUrl="@DemoPaperlessUrl"
                        ServiceLogin="@DemoServiceLogin" />
        }
        <MudContainer MaxWidth="MaxWidth.False" Class="pa-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@* E2E sentinel — only rendered after OnAfterRenderAsync(firstRender),
   which guarantees the SignalR circuit is connected and event handlers
   are bound. Playwright waits for this before clicking. *@
@if (_circuitReady)
{
    <div id="blazor-circuit-ready" style="display:none"></div>
}
