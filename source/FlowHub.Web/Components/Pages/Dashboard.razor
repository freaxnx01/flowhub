@page "/"
@rendermode InteractiveServer

<PageTitle>FlowHub — Dashboard</PageTitle>

@if (_loadError is not null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">
        Could not load dashboard data: @_loadError
        <MudButton Variant="Variant.Text" OnClick="LoadAsync" Class="ml-2">Retry</MudButton>
    </MudAlert>
}

<MudStack Spacing="4">

    <NeedsAttentionCard Counts="_failureCounts"
                        OnOrphanClick="NavigateToOrphans"
                        OnUnhandledClick="NavigateToUnhandled" />

    <RecentCapturesCard Captures="_recent"
                        OnRowClick="NavigateToCapture"
                        OnViewAllClick="NavigateToAllCaptures" />

    <MudGrid>
        <MudItem xs="12" md="6">
            <SkillHealthCard Skills="_skills" OnManageClick="NavigateToSkills" />
        </MudItem>
        <MudItem xs="12" md="6">
            <IntegrationHealthCard Integrations="_integrations" OnManageClick="NavigateToIntegrations" />
        </MudItem>
    </MudGrid>

</MudStack>
