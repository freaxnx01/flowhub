@page "/captures"
@rendermode InteractiveServer

<PageTitle>FlowHub — Captures</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">Captures</MudText>

@if (_loadError is not null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">
        Could not load captures: @_loadError
        <MudButton Variant="Variant.Text" OnClick="LoadAsync" Class="ml-2">Retry</MudButton>
    </MudAlert>
}

@* Filter bar *@
<MudPaper Outlined="true" Class="pa-4 mb-4">
    <MudStack Spacing="2">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudText Typo="Typo.body2" Style="min-width:80px;">Lifecycle:</MudText>
            <MudChipSet T="LifecycleStage?"
                        @bind-SelectedValue="_selectedLifecycle"
                        SelectionMode="SelectionMode.SingleSelection"
                        CheckMark="false"
                        @bind-SelectedValue:after="ApplyFilters">
                <MudChip T="LifecycleStage?" Value="@((LifecycleStage?)null)" Default="true">All</MudChip>
                @foreach (var stage in Enum.GetValues<LifecycleStage>())
                {
                    <MudChip T="LifecycleStage?" Value="@((LifecycleStage?)stage)">@stage</MudChip>
                }
            </MudChipSet>
        </MudStack>

        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudText Typo="Typo.body2" Style="min-width:80px;">Channel:</MudText>
            <MudChipSet T="ChannelKind?"
                        @bind-SelectedValue="_selectedChannel"
                        SelectionMode="SelectionMode.SingleSelection"
                        CheckMark="false"
                        @bind-SelectedValue:after="ApplyFilters">
                <MudChip T="ChannelKind?" Value="@((ChannelKind?)null)" Default="true">All</MudChip>
                @foreach (var ch in Enum.GetValues<ChannelKind>())
                {
                    <MudChip T="ChannelKind?" Value="@((ChannelKind?)ch)">@ch</MudChip>
                }
            </MudChipSet>

            <MudSpacer />

            <MudTextField T="string"
                          @bind-Value="_searchText"
                          @bind-Value:after="ApplyFilters"
                          Placeholder="Search content…"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Clearable="true"
                          Immediate="true"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Style="max-width:300px;" />
        </MudStack>
    </MudStack>
</MudPaper>

@* Data grid *@
@if (_allCaptures is null)
{
    @for (var i = 0; i < 5; i++)
    {
        <MudSkeleton Height="36px" Class="mb-1" />
    }
}
else if (_allCaptures.Count == 0)
{
    <MudPaper Outlined="true" Class="pa-8">
        <MudStack AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Inbox" Size="Size.Large" Color="Color.Default" />
            <MudText Typo="Typo.body1" Align="Align.Center">No captures yet. Send something via Telegram, or use the quick-capture field above.</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="captures/new" StartIcon="@Icons.Material.Filled.Add">New Capture</MudButton>
        </MudStack>
    </MudPaper>
}
else if (_filtered!.Count == 0)
{
    <MudPaper Outlined="true" Class="pa-8">
        <MudStack AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Color="Color.Default" />
            <MudText Typo="Typo.body1" Align="Align.Center">No captures match the current filters.</MudText>
            <MudButton Variant="Variant.Outlined" OnClick="ClearFilters">Clear filters</MudButton>
        </MudStack>
    </MudPaper>
}
else
{
    <MudText Typo="Typo.body2" Color="Color.Default" Class="mb-2">Results: @_filtered.Count</MudText>
    <MudDataGrid T="Capture"
                 Items="@_filtered"
                 Dense="true"
                 Hover="true"
                 RowClick="OnRowClick"
                 RowsPerPage="10"
                 SortMode="SortMode.Single">
        <Columns>
            <PropertyColumn Property="x => x.CreatedAt" Title="When" InitialDirection="SortDirection.Descending">
                <CellTemplate>
                    <MudText Typo="Typo.body2">@FormatRelative(context.Item.CreatedAt)</MudText>
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Source" Title="Ch">
                <CellTemplate>
                    <MudIcon Icon="@(context.Item.Source == ChannelKind.Telegram ? Icons.Material.Filled.Send : Icons.Material.Filled.Computer)"
                             Size="Size.Small" />
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Stage" Title="State">
                <CellTemplate>
                    <LifecycleBadge Stage="@context.Item.Stage" />
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Content" Title="Content">
                <CellTemplate>
                    <MudText Typo="Typo.body2" Style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:380px;">
                        @context.Item.Content
                    </MudText>
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.MatchedSkill" Title="Skill">
                <CellTemplate>
                    <MudText Typo="Typo.body2">@(context.Item.MatchedSkill ?? "—")</MudText>
                </CellTemplate>
            </PropertyColumn>
        </Columns>
        <PagerContent>
            <MudDataGridPager T="Capture" PageSizeOptions="@(new[] { 10, 25, 50 })" />
        </PagerContent>
    </MudDataGrid>
}
