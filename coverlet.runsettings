<?xml version="1.0" encoding="utf-8"?>
<!-- Coverage settings for the XPlat Code Coverage collector.
     Excludes generated / non-unit-testable code so the number reflects hand-written logic.
     Usage: dotnet test ... [collect XPlat Code Coverage] [settings coverlet.runsettings] -->
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat Code Coverage">
        <Configuration>
          <Format>cobertura</Format>
          <!-- Explicit Include captures ALL FlowHub.* assemblies regardless of
               which test project loaded them. Without it, coverlet's default
               "module under test" heuristic only instruments the test project's
               directly-referenced assembly, so a transitive dep (e.g. FlowHub.AI
               loaded by Web.ComponentTests via FlowHub.Web) reads 0% on CI
               even when its tests run. Local sometimes works without this
               (different default behaviour by env) but the gate needs
               determinism — `[FlowHub.*]*` makes it deterministic across both. -->
          <Include>[FlowHub.*]*</Include>
          <ExcludeByFile>**/Migrations/*.cs,**/*.g.cs,**/*.Designer.cs</ExcludeByFile>
          <ExcludeByAttribute>System.CodeDom.Compiler.GeneratedCodeAttribute,System.Runtime.CompilerServices.CompilerGeneratedAttribute,System.Diagnostics.CodeAnalysis.ExcludeFromCodeCoverageAttribute</ExcludeByAttribute>
          <SkipAutoProps>true</SkipAutoProps>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
