# FlowHub local secrets — copy to `.env` (gitignored) and fill in real values.
# The Makefile auto-loads `.env` via `-include .env`, so every `make` target
# (notably ai-ping / ai-classify / ai-embed) picks these up automatically.
#
# Passbolt users: values may be `passbolt://<resource-id>` references. The
# ai-* and smoke-* targets re-source .env into the recipe shell and run via
# `passbolt exec --` (if installed), which resolves the refs at call time.
# No code path stores resolved secrets on disk.

# --- Chat / classification provider -----------------------------------------
# Pick one provider and set the matching ApiKey.
# Supported: Anthropic | OpenRouter
Ai__Provider=OpenRouter

# Anthropic (https://console.anthropic.com)
# Ai__Anthropic__ApiKey=sk-ant-...
# Ai__Anthropic__Model=claude-sonnet-4-6

# OpenRouter (https://openrouter.ai/keys)
Ai__OpenRouter__ApiKey=sk-or-v1-...
# Ai__OpenRouter__Model=meta-llama/llama-3.1-70b-instruct

# --- Embeddings (OpenAI-compatible endpoint) --------------------------------
# Default model is `mistral-embed`, so the example below points at Mistral.
# Any OpenAI-compatible /v1/embeddings endpoint works (OpenAI, Mistral, …).
Embeddings__ApiKey=...
Embeddings__BaseUrl=https://api.mistral.ai/v1
# Embeddings__Model=mistral-embed
# Dimensions is only honoured by OpenAI's text-embedding-3-* family. Mistral's
# mistral-embed rejects the field with 422; leave commented when using Mistral.
# Embeddings__Dimensions=1024
# Embeddings__TimeoutSeconds=10
